<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Tema principal de la app -->
    <style name="Theme.DndCompanion" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/dorado</item>
        <item name="colorPrimaryVariant">@color/dorado_borde</item>
        <item name="colorOnPrimary">@color/fondo</item>
        <item name="colorSurface">@color/seccion_fondo</item>
        <item name="android:windowBackground">@color/fondo</item>
    </style>

    <!-- Diálogo con estética oscura de la app -->
    <style name="DialogoOscuro" parent="Theme.MaterialComponents.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.7</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowMinWidthMajor">90%</item>
        <item name="android:windowMinWidthMinor">90%</item>
    </style>

</resources>