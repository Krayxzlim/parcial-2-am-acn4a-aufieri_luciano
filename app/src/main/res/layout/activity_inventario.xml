<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/fondo"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- HEADER -->
    <LinearLayout android:id="@+id/headerInv"
        android:orientation="vertical" android:gravity="center"
        android:paddingTop="14dp" android:paddingBottom="8dp"
        android:layout_width="0dp" android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <TextView android:text="D&amp;D Companion" android:textColor="@color/dorado"
            android:textSize="24sp" android:textStyle="bold" android:fontFamily="serif"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <TextView android:text="INVENTARIO" android:textColor="@color/dorado_claro"
            android:textSize="10sp" android:letterSpacing="0.12"
            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/dorado"
            android:layout_marginStart="12dp" android:layout_marginEnd="12dp" android:layout_marginTop="8dp"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="0dp" android:layout_height="0dp"
        android:scrollbars="none"
        app:layout_constraintTop_toBottomOf="@id/headerInv"
        app:layout_constraintBottom_toTopOf="@id/bottomMenuInv"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout android:orientation="vertical"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:padding="8dp">

            <!-- Capacidad de carga -->
            <LinearLayout android:orientation="vertical"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:padding="10dp"
                android:background="@drawable/seccion_bg">

                <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="🎒" android:textSize="14sp"
                        android:layout_marginEnd="6dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="CARGA" android:textColor="@color/dorado"
                        android:textSize="13sp" android:textStyle="bold" android:fontFamily="serif"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <TextView android:text="12 / 120 lb" android:textColor="@color/dorado_claro"
                        android:textSize="12sp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/borde"
                    android:layout_marginTop="6dp" android:layout_marginBottom="8dp"/>

                <!-- Barra de carga -->
                <LinearLayout android:orientation="horizontal"
                    android:layout_width="match_parent" android:layout_height="8dp"
                    android:background="@drawable/stat_bg">
                    <View android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="10" android:background="@color/dorado"/>
                    <View android:layout_width="0dp" android:layout_height="match_parent"
                        android:layout_weight="90"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Monedas -->
            <LinearLayout android:orientation="vertical"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:padding="10dp"
                android:background="@drawable/seccion_bg">

                <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="💰" android:textSize="14sp"
                        android:layout_marginEnd="6dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="MONEDAS" android:textColor="@color/dorado"
                        android:textSize="13sp" android:textStyle="bold" android:fontFamily="serif"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/borde"
                    android:layout_marginTop="6dp" android:layout_marginBottom="8dp"/>

                <LinearLayout android:orientation="horizontal"
                    android:layout_width="match_parent" android:layout_height="wrap_content">

                    <LinearLayout android:orientation="vertical" android:gravity="center"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                        <TextView android:text="PP" android:textColor="@color/texto_secundario" android:textSize="9sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="0" android:textColor="@color/texto" android:textSize="16sp" android:textStyle="bold"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <LinearLayout android:orientation="vertical" android:gravity="center"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                        <TextView android:text="PO" android:textColor="@color/dorado_claro" android:textSize="9sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="45" android:textColor="@color/dorado" android:textSize="16sp" android:textStyle="bold"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <LinearLayout android:orientation="vertical" android:gravity="center"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                        <TextView android:text="PE" android:textColor="@color/texto_secundario" android:textSize="9sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="0" android:textColor="@color/texto" android:textSize="16sp" android:textStyle="bold"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                    <LinearLayout android:orientation="vertical" android:gravity="center"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                        <TextView android:text="PC" android:textColor="@color/texto_secundario" android:textSize="9sp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <TextView android:text="12" android:textColor="@color/texto" android:textSize="16sp" android:textStyle="bold"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Objetos -->
            <LinearLayout android:orientation="vertical"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" android:padding="10dp"
                android:background="@drawable/seccion_bg">

                <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
                    android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="⚔" android:textSize="14sp" android:textColor="@color/dorado"
                        android:layout_marginEnd="6dp"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="OBJETOS" android:textColor="@color/dorado"
                        android:textSize="13sp" android:textStyle="bold" android:fontFamily="serif"
                        android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                    <Button android:id="@+id/btnAgregarObjeto"
                        android:text="＋" android:textColor="@color/dorado"
                        android:backgroundTint="@color/boton_bg" android:textSize="14sp"
                        android:layout_width="36dp" android:layout_height="30dp" android:padding="0dp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/borde"
                    android:layout_marginTop="6dp" android:layout_marginBottom="6dp"/>

                <LinearLayout android:id="@+id/layoutObjetos" android:orientation="vertical"
                    android:layout_width="match_parent" android:layout_height="wrap_content">

                    <!-- Ejemplo 1 -->
                    <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingTop="8dp" android:paddingBottom="8dp"
                        android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:text="🗡️" android:textSize="20sp"
                            android:layout_marginEnd="10dp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <LinearLayout android:orientation="vertical"
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                            <TextView android:text="Espada Corta +1" android:textColor="@color/texto"
                                android:textSize="13sp" android:textStyle="bold"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:text="Arma · 1 lb · Daño: 1d6+1 perforante"
                                android:textColor="@color/texto_secundario" android:textSize="11sp"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                        <TextView android:text="Eq." android:textColor="@color/dorado"
                            android:textSize="10sp" android:background="@drawable/stat_bg"
                            android:padding="4dp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/borde"/>

                    <!-- Ejemplo 2 -->
                    <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingTop="8dp" android:paddingBottom="8dp"
                        android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:text="🧪" android:textSize="20sp"
                            android:layout_marginEnd="10dp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <LinearLayout android:orientation="vertical"
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                            <TextView android:text="Poción de Curación" android:textColor="@color/texto"
                                android:textSize="13sp" android:textStyle="bold"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:text="Consumible · 0.5 lb · Cura 2d4+2 PG"
                                android:textColor="@color/texto_secundario" android:textSize="11sp"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                        <TextView android:text="x3" android:textColor="@color/dorado_claro"
                            android:textSize="12sp" android:textStyle="bold"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/borde"/>

                    <!-- Ejemplo 3 -->
                    <LinearLayout android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingTop="8dp" android:paddingBottom="8dp"
                        android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:text="📜" android:textSize="20sp"
                            android:layout_marginEnd="10dp"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        <LinearLayout android:orientation="vertical"
                            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
                            <TextView android:text="Pergamino de Bola de Fuego" android:textColor="@color/texto"
                                android:textSize="13sp" android:textStyle="bold"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                            <TextView android:text="Pergamino mágico · Nivel 3"
                                android:textColor="@color/texto_secundario" android:textSize="11sp"
                                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- MENÚ INFERIOR -->
    <LinearLayout android:id="@+id/bottomMenuInv"
        android:orientation="horizontal"
        android:background="@drawable/seccion_bg"
        android:paddingTop="6dp" android:paddingBottom="6dp"
        android:layout_width="0dp" android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout android:id="@+id/menuInicio"
            android:orientation="vertical" android:gravity="center"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
            <TextView android:text="✦" android:textColor="@color/texto_secundario" android:textSize="16sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="INICIO" android:textColor="@color/texto_secundario" android:textSize="10sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/menuInventario"
            android:orientation="vertical" android:gravity="center"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
            <TextView android:text="🎒" android:textSize="16sp" android:textColor="@color/dorado"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="INVENTARIO" android:textColor="@color/dorado" android:textSize="10sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/menuNotas"
            android:orientation="vertical" android:gravity="center"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
            <TextView android:text="📖" android:textSize="16sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="NOTAS" android:textColor="@color/texto_secundario" android:textSize="10sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
        <LinearLayout android:id="@+id/menuAjustes"
            android:orientation="vertical" android:gravity="center"
            android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1">
            <TextView android:text="⚙" android:textColor="@color/texto_secundario" android:textSize="16sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
            <TextView android:text="AJUSTES" android:textColor="@color/texto_secundario" android:textSize="10sp"
                android:layout_width="wrap_content" android:layout_height="wrap_content"/>
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>